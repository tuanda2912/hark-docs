{
  "name": "hark-docs-site",
  "version": "1.0.0",
  "description": "Static-site generator for hark-docs/docs (marked + highlight.js → docs/site/).",
  "type": "module",
  "scripts": {
    "build": "node build-site.mjs",
    "serve": "node build-site.mjs && cd ../docs/site && python3 -m http.server 8000",
    "open": "node build-site.mjs && open ../docs/site/index.html"
  },
  "license": "ISC",
  "dependencies": {
    "highlight.js": "^11.11.1",
    "marked": "^4.3.0"
  }
}
