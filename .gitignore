# Docs-site build tooling: the generator + assets are tracked, deps are not.
tools/node_modules/

# Obsidian: ignore only the volatile per-machine state (matched at any depth, since
# the vault lives at wiki/.obsidian/, not the repo root).
# .obsidian/graph.json (the colored graph-view recipe), app.json, appearance.json,
# and core-plugins.json ARE tracked so the configured graph travels with the repo.
**/.obsidian/workspace.json
**/.obsidian/workspace-mobile.json

# Cairn: local safety backup (old wiki is preserved in git history) + machine-local path config
_cairn-backup-2026-06-30/
.claude/wiki.config.local.sh
.cairn-manifest.json
